# 复制为 .env 并修改
NAVBI_DB_PASSWORD=change-me-db
NAVBI_ADMIN_USERNAME=admin
NAVBI_ADMIN_PASSWORD=change-me-admin
# 至少 32 字节
NAVBI_JWT_SECRET=change-me-to-a-random-32byte-secret!!
# 验证码邮件 API（不配置则验证码只打后端日志）
NAVBI_MAIL_API_URL=https://monitor.magies.top/mail-api/send-code
NAVBI_MAIL_API_TOKEN=change-me-mail-token
